# Node dependencies (reinstalled during build)
node_modules/

# Build output (rebuilt during Docker build)
dist/
build/

# NOTE: Do not list `.env` / `.env.local` here. Vite inlines `import.meta.env.VITE_*`
# at *image build* time. Cloud Run runtime environment variables are not visible to
# the static nginx bundle, so excluding env files produces a client with no Firebase
# config (Firestore profile load/save fails; users see onboarding + save errors).

# Google Cloud SDK — extracted locally, not needed in container
google-cloud-sdk/
google-cloud-cli-*.tar.gz

# Firebase local cache
.firebase/

# Editor / OS artifacts
.DS_Store
*.log
.claude/
.antigravity/

# Agent skills and docs
.agents/
docs/superpowers/

# Coverage reports
coverage/
