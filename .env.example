# ==========================================
# Mama AI - Environment Variables
# Copy this file to .env.local and fill in your values
# ==========================================

# ----------------------------------------------------
# Google Gemini API Key
# Get yours at: https://ai.google.dev/
# Required for: Live API, image generation, video generation, embeddings
# ----------------------------------------------------
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# ----------------------------------------------------
# Firebase Configuration
# Create a project at: https://console.firebase.google.com/
# Required for: Auth, Firestore, Cloud Storage
# ----------------------------------------------------
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# ----------------------------------------------------
# Optional: Demo Account Details
# Used for the "Skip" button on Login/Signup pages to easily demo the app
# ----------------------------------------------------
VITE_DEMO_EMAIL=demo@mama.ai
VITE_DEMO_PASSWORD=password123

# ----------------------------------------------------
# Optional: Custom API Endpoints (for advanced use)
# ----------------------------------------------------
# VITE_API_BASE_URL=http://localhost:3000
